# Public app URL
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Stripe
STRIPE_SECRET_KEY=sk_live_or_test
STRIPE_WEBHOOK_SECRET=whsec_from_stripe_cli_or_dashboard
STRIPE_MONTHLY_PRICE_ID=price_monthly_gb
STRIPE_YEARLY_PRICE_ID=price_yearly_gb

# Optional region price IDs for scalability
STRIPE_MONTHLY_PRICE_ID_US=price_monthly_us
STRIPE_YEARLY_PRICE_ID_US=price_yearly_us
STRIPE_MONTHLY_PRICE_ID_EU=price_monthly_eu
STRIPE_YEARLY_PRICE_ID_EU=price_yearly_eu

# Email notifications (Resend)
RESEND_API_KEY=re_xxx
RESEND_FROM_EMAIL=GolfDraw <noreply@yourdomain.com>

# Feature flags
NEXT_PUBLIC_ENABLE_CAMPAIGNS=false
